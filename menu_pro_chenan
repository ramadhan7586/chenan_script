local function loadItems(category)
    for _, child in ipairs(itemScroll:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local count = 0
    for _, item in ipairs(assetList) do
        if category == "Semua" or item.Category == category then
            count = count + 1
            local r = Instance.new("Frame", itemScroll); r.Size, r.BackgroundTransparency = UDim2.new(0.96, 0, 0, 22), 1
            local s = createAestheticBtn(item.Name, UDim2.new(0, 0, 0, 0), UDim2.new(0.8, -2, 1, 0), r, Color3.fromRGB(30, 30, 35))
            local d = createAestheticBtn("🗑", UDim2.new(0.8, 0, 0, 0), UDim2.new(0.2, 0, 1, 0), r, Color3.fromRGB(120, 40, 40))
            
            s.MouseButton1Click:Connect(function()
                if selectedButton then selectedButton.BackgroundColor3 = Color3.fromRGB(30, 30, 35) end
                selectedButton = s; s.BackgroundColor3 = Color3.fromRGB(50, 80, 120); currentItemID = item.ID
                if previewModel then previewModel:Destroy() end
                resetSliderTo(1.0)
                local success, objs = pcall(function() return game:GetObjects("rbxassetid://" .. item.ID) end)
                if success and objs[1] then
                    previewModel = objs[1]; previewModel.Parent = workspace
                    for _, b in pairs(previewModel:GetDescendants()) do if b:IsA("BasePart") then b.Transparency = 0.5; b.CanCollide = false; b.Anchored = true end end
                    local root = LP.Character.HumanoidRootPart; local spawnPos = root.Position + (root.CFrame.LookVector * 8)
                    local groundPos = getGroundPrecision(spawnPos, previewModel)
                    previewModel:PivotTo(CFrame.new(groundPos) * CFrame.Angles(0, math.rad(root.Orientation.Y), 0))
                    previewModel:ScaleTo(1.0); PlaceBtn.Visible = true
                end
            end)
            d.MouseButton1Click:Connect(function()
                local list = spawnedObjects[item.ID]
                if list and #list > 0 then list[#list]:Destroy(); table.remove(list, #list); lastSelectedModel = list[#list] end
            end)
        end
    end
    itemScroll.CanvasSize = UDim2.new(0, 0, 0, count * 25)
end

