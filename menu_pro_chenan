local function moveMod(act)
    local t = previewModel or lastSelectedModel; if not t then return end
    local cf, s, v_s = t:GetPivot(), 2.5, 1
    if act == "F" then t:PivotTo(cf * CFrame.new(0,0,-s)) elseif act == "B" then t:PivotTo(cf * CFrame.new(0,0,s))
    elseif act == "L" then t:PivotTo(cf * CFrame.new(-s,0,0)) elseif act == "R" then t:PivotTo(cf * CFrame.new(s,0,0))
    elseif act == "U" then t:PivotTo(cf * CFrame.new(0,v_s,0)) elseif act == "D" then t:PivotTo(cf * CFrame.new(0,-v_s,0))
    elseif act == "RL" then t:PivotTo(cf * CFrame.Angles(0,math.rad(15),0)) elseif act == "RR" then t:PivotTo(cf * CFrame.Angles(0,math.rad(-15),0)) end
end

