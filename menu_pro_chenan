local function getGroundPrecision(pos, model)
    local p = RaycastParams.new(); p.FilterDescendantsInstances = {model, LP.Character}
    local ray = workspace:Raycast(pos + Vector3.new(0, 100, 0), Vector3.new(0, -300, 0), p)
    local floorY = ray and ray.Position.Y or (LP.Character.HumanoidRootPart.Position.Y - 3)
    local bboxCFrame, size = model:GetBoundingBox(); local pivot = model:GetPivot(); local offsetY = pivot.Y - bboxCFrame.Y
    return Vector3.new(pos.X, floorY + (size.Y/2) + offsetY, pos.Z)
end

local draggingSlider, minScale, maxScale, currentScale = false, 0.1, 5.0, 1.0
local function updateSlider(input)
    local posX = math.clamp(input.Position.X - SliderBG.AbsolutePosition.X, 0, SliderBG.AbsoluteSize.X); local percent = posX / SliderBG.AbsoluteSize.X
    SliderKnob.Position = UDim2.new(percent, -4, 0.5, -4); SliderFill.Size = UDim2.new(percent, 0, 1, 0)
    currentScale = math.round((minScale + (percent * (maxScale - minScale))) * 10) / 10; SliderLabel.Text = "Ukuran Items: " .. currentScale .. "x"
    local target = previewModel or lastSelectedModel; if target then target:ScaleTo(currentScale) end
end
local function resetSliderTo(sVal)
    currentScale = sVal; local percent = (sVal - minScale) / (maxScale - minScale)
    SliderKnob.Position = UDim2.new(percent, -4, 0.5, -4); SliderFill.Size = UDim2.new(percent, 0, 1, 0); SliderLabel.Text = "Ukuran Items: " .. currentScale .. "x"
end
