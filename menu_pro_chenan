local function ApplyScale(character, scaleNum)
    local hum = character and character:FindFirstChild("Humanoid")
    if hum then
        for _, sName in ipairs({"BodyHeightScale", "BodyWidthScale", "BodyDepthScale", "HeadScale"}) do
            local sVal = hum:FindFirstChild(sName)
            if sVal and sVal:IsA("NumberValue") then sVal.Value = scaleNum end
        end
    end
end

