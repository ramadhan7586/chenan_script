-- FUNGSI LED REKLAME (MARQUEE LOOP SEARAH)
local function playLEDMarquee(lbl, duration)
    lbl.Size = UDim2.new(2, 0, 1, 0)
    lbl.Position = UDim2.new(-1, 0, 0, 0)
    -- Bergerak ke kanan lalu reset otomatis dari kiri
    local tw = TS:Create(lbl, TweenInfo.new(duration, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut, -1, false), {Position = UDim2.new(1, 0, 0, 0)})
    tw:Play()
end

