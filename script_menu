end

local function resetCamera()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        workspace.CurrentCamera.CameraSubject = LocalPlayer.Character.Humanoid
    end
end

local function buildMenuDinamis()
    DigSpotsFolder = workspace:FindFirstChild("DigSpots")
    for _, child in pairs(DigScrollFrame:GetChildren()) do
        if not child:IsA("UIListLayout") then child:Destroy() end
    end

    if not DigSpotsFolder then return end

    for _, k in ipairs(KelangkaanData) do
        local galianDitemukan = {}
        for _, spot in pairs(DigSpotsFolder:GetChildren()) do
            if string.find(spot.Name, k.Id) then
                if not knownSpots[spot] then
                    spotCounters[k.Id] = (spotCounters[k.Id] or 0) + 1
                    knownSpots[spot] = spotCounters[k.Id]
                end
                table.insert(galianDitemukan, spot)
            end
        end

        if #galianDitemukan > 0 then
            table.sort(galianDitemukan, function(a, b)
                return knownSpots[a] < knownSpots[b]
            end)

            local CategoryGroupFrame = Instance.new("Frame", DigScrollFrame)
            CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30)
            CategoryGroupFrame.BackgroundTransparency = 1
            CategoryGroupFrame.LayoutOrder = k.Order
            CategoryGroupFrame.ClipsDescendants = true 
            
            local GroupList = Instance.new("UIListLayout", CategoryGroupFrame)
            GroupList.Padding = UDim.new(0, 3)
            GroupList.HorizontalAlignment = Enum.HorizontalAlignment.Center
            GroupList.VerticalAlignment = Enum.VerticalAlignment.Top

            local MainCatButton = Instance.new("TextButton", CategoryGroupFrame)
            MainCatButton.Size = UDim2.new(1, -6, 0, 30)
            MainCatButton.BackgroundColor3 = WARNA_PINK_TUA 
            MainCatButton.Text = "  " .. k.Display .. " (" .. #galianDitemukan .. ")"
            MainCatButton.TextColor3 = Color3.fromRGB(255, 255, 255)
            MainCatButton.Font = Enum.Font.Ubuntu
            MainCatButton.TextXAlignment = Enum.TextXAlignment.Left
            MainCatButton.TextSize = 13
            Instance.new("UICorner", MainCatButton).CornerRadius = UDim.new(0, 5)

            local ExpandIndicator = Instance.new("TextLabel", MainCatButton)
            ExpandIndicator.Size = UDim2.new(0, 25, 1, 0)
            ExpandIndicator.Position = UDim2.new(1, -30, 0, 0)
            ExpandIndicator.BackgroundTransparency = 1
            ExpandIndicator.Text = "[ + ]"
            ExpandIndicator.TextColor3 = Color3.fromRGB(255, 255, 255)
            ExpandIndicator.Font = Enum.Font.Ubuntu
            ExpandIndicator.TextSize = 12

            local isExpanded = expandedCategories[k.Id] or false 
            local SubFramesList = {}

            for _, spotObject in ipairs(galianDitemukan) do
                local index = knownSpots[spotObject]

                local SubItemFrame = Instance.new("Frame", CategoryGroupFrame)
                SubItemFrame.Size = UDim2.new(0.92, 0, 0, 28)
                SubItemFrame.BackgroundTransparency = 1
                SubItemFrame.Visible = false
                table.insert(SubFramesList, SubItemFrame)

                local SubButton = Instance.new("TextButton", SubItemFrame)
                SubButton.Size = UDim2.new(0.78, 0, 1, 0)
                SubButton.BackgroundColor3 = WARNA_UNGU 
                SubButton.Text = "📍 " .. k.Id .. " " .. index
                SubButton.TextColor3 = Color3.fromRGB(255, 255, 255)
                SubButton.Font = Enum.Font.Ubuntu
                SubButton.TextSize = 12
                Instance.new("UICorner", SubButton).CornerRadius = UDim.new(0, 4)
                
                local EyeBtn = Instance.new("TextButton", SubItemFrame)
                EyeBtn.Size = UDim2.new(0.2, 0, 1, 0)
                EyeBtn.Position = UDim2.new(0.8, 0, 0, 0)
                EyeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                EyeBtn.Text = "👁️"
                EyeBtn.Font = Enum.Font.Ubuntu
                EyeBtn.TextSize = 13
                Instance.new("UICorner", EyeBtn).CornerRadius = UDim.new(0, 4)

                if TerpilihObject == spotObject then
                    SubButton.BackgroundColor3 = WARNA_BIRU
                end

                SubButton.MouseButton1Click:Connect(function()
                    for _, folder in pairs(DigScrollFrame:GetChildren()) do
                        if folder:IsA("Frame") then
                            for _, subFrame in pairs(folder:GetChildren()) do
                                if subFrame:IsA("Frame") then
                                    local btn = subFrame:FindFirstChildOfClass("TextButton")
                                    if btn then btn.BackgroundColor3 = WARNA_UNGU end
                                end
                            end
                        end
                    end
                    SubButton.BackgroundColor3 = WARNA_BIRU 
                    TerpilihObject = spotObject
                    TerpilihName = k.Id .. " " .. index
                    StatusLabel.Text = "Target Pas: " .. TerpilihName
                    StatusLabel.TextColor3 = WARNA_BIRU 
                end)

                EyeBtn.MouseButton1Click:Connect(function()
                    local targetPart = spotObject:IsA("BasePart") and spotObject or spotObject:FindFirstChildWhichIsA("BasePart") or spotObject.PrimaryPart
                    if targetPart then
                        if workspace.CurrentCamera.CameraSubject == targetPart then
                            resetCamera()
                            EyeBtn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                        else
                            workspace.CurrentCamera.CameraSubject = targetPart
                            for _, folder in pairs(DigScrollFrame:GetChildren()) do
                                if folder:IsA("Frame") then
                                    for _, sub in pairs(folder:GetChildren()) do
                                        if sub:IsA("Frame") then
                                            local e = sub:GetChildren()[2] 
                                            if e and e:IsA("TextButton") then e.BackgroundColor3 = Color3.fromRGB(60, 60, 60) end
                                        end
                                    end
                                end
                            end
                            EyeBtn.BackgroundColor3 = WARNA_BIRU
                        end
                    end
                end)
            end

            if isExpanded then
                ExpandIndicator.Text = "[ - ]"
                CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30 + (#SubFramesList * 31))
                for _, f in ipairs(SubFramesList) do f.Visible = true end
            else
                ExpandIndicator.Text = "[ + ]"
                CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30)
                for _, f in ipairs(SubFramesList) do f.Visible = false end
            end

            MainCatButton.MouseButton1Click:Connect(function()
                isExpanded = not isExpanded
                expandedCategories[k.Id] = isExpanded 
                if isExpanded then
                    ExpandIndicator.Text = "[ - ]"
                    CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30 + (#SubFramesList * 31))
                    for _, f in ipairs(SubFramesList) do f.Visible = true end
                else
                    ExpandIndicator.Text = "[ + ]"
                    CategoryGroupFrame.Size = UDim2.new(1, 0, 0, 30)
                    for _, f in ipairs(SubFramesList) do f.Visible = false end
                end
                task.wait(0.01)
                recalculateCanvas()
            end)
        end
    end
    task.wait(0.02)
    recalculateCanvas()
end

local digUpdateDebounce = false
local function autoRefreshDigMenu()
    if MenuFrame.Visible and not digUpdateDebounce then
        digUpdateDebounce = true
        task.delay(0.5, function() 
            if MenuFrame.Visible then
                buildMenuDinamis()
            end
            digUpdateDebounce = false
        end)
    end
end

local digConAdded, digConRemoved
local function attachDigListener()
    if digConAdded then digConAdded:Disconnect() end
    if digConRemoved then digConRemoved:Disconnect() end
    
    local folder = workspace:FindFirstChild("DigSpots")
    if folder then
        digConAdded = folder.ChildAdded:Connect(autoRefreshDigMenu)
        digConRemoved = folder.ChildRemoved:Connect(autoRefreshDigMenu)
    end
end

workspace.ChildAdded:Connect(function(child)
    if child.Name == "DigSpots" then
        attachDigListener()
        autoRefreshDigMenu()
    end
end)
attachDigListener() 

