local monsterData = {} 
local function getRoot(monster)
    return monster.PrimaryPart or monster:FindFirstChild("HumanoidRootPart") or monster:FindFirstChildWhichIsA("BasePart")
end

RunService.Heartbeat:Connect(function(deltaTime)
    local folder = workspace:FindFirstChild("MonsterDrivers")
    if not folder then return end

    for _, monster in ipairs(folder:GetChildren()) do
        
        if monConfig.Hapus then
            if monster:IsDescendantOf(workspace) then
                monster:Destroy()
            end
            continue
        end

        local root = getRoot(monster)
        if not root then continue end
        
        if not monsterData[monster] then
            monsterData[monster] = { LastPos = root.Position, HasMoved = false }
        end
        
        local data = monsterData[monster]
        local speed = (root.Position - data.LastPos).Magnitude / deltaTime
        data.LastPos = root.Position
        
        if speed > 1.5 then 
            data.HasMoved = true 
        end
        
        local showText = false
        local showBox = false

        if monConfig.Hidup and data.HasMoved then showText = true end
        if monConfig.Semua then
            if data.HasMoved then showText = true else showBox = true end
        end

        if showText then
            if not data.TextESP then
                local bill = Instance.new("BillboardGui")
                bill.Size = UDim2.new(0, 200, 0, 40)
                bill.StudsOffset = Vector3.new(0, 4, 0)
                bill.AlwaysOnTop = true
                
                local txt = Instance.new("TextLabel")
                txt.Size = UDim2.new(1, 0, 1, 0)
                txt.BackgroundTransparency = 1
                txt.Text = "AWAS MONSTER"
                txt.TextColor3 = ThemeMonster.YellowAcc
                txt.Font = Enum.Font.GothamBlack
                txt.TextSize = 16 
                txt.TextStrokeTransparency = 0.2
                txt.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
                txt.Parent = bill
                
                bill.Parent = root
                data.TextESP = bill
            end
        else
            if data.TextESP then
                data.TextESP:Destroy()
                data.TextESP = nil
            end
        end

        if showBox then
            if not data.AestheticBox then
                local box = Instance.new("SelectionBox")
                box.Adornee = monster 
                box.LineThickness = 0.05
                box.Color3 = ThemeMonster.PinkNeon
                box.SurfaceColor3 = ThemeMonster.PinkSoft
                box.SurfaceTransparency = 0.8
                box.Parent = root
                data.AestheticBox = box
            end
        else
            if data.AestheticBox then
                data.AestheticBox:Destroy()
                data.AestheticBox = nil
            end
        end
    end
    
    for m, _ in pairs(monsterData) do
        if not m.Parent then 
            if monsterData[m].TextESP then monsterData[m].TextESP:Destroy() end
            if monsterData[m].AestheticBox then monsterData[m].AestheticBox:Destroy() end
            monsterData[m] = nil
        end
    end
end)


