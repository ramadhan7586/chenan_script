local notifiedSpots = {}

local function CheckForRareSpots(spot)
    if notifiedSpots[spot] then return end
    notifiedSpots[spot] = true
    
    local rarityFound = nil
    if string.find(spot.Name, "Legendary") then rarityFound = "Legendary"
    elseif string.find(spot.Name, "Ancient") then rarityFound = "Ancient"
    elseif string.find(spot.Name, "Epic") then rarityFound = "Epic"
    end
    
    if rarityFound then
        SpawnNotification(rarityFound, spot)
    end
end

local function AttachRareNotifListener()
    local folder = workspace:FindFirstChild("DigSpots")
    if folder then
        for _, spot in pairs(folder:GetChildren()) do
            CheckForRareSpots(spot)
        end
        folder.ChildAdded:Connect(CheckForRareSpots)
    end
end

workspace.ChildAdded:Connect(function(child)
    if child.Name == "DigSpots" then
        AttachRareNotifListener()
    end
end)

AttachRareNotifListener()